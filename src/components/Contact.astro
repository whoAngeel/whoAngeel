<section id="contacto" class="max-w-lg mx-auto w-full px-8 py-24">
  <h2 class="section-title text-4xl font-bold text-charm-text mb-3">Contacto</h2>
  <p class="text-charm-muted mb-8">Hablemos. Estoy abierto a colaboraciones, oportunidades o solo un café virtual.</p>

  <div class="space-y-4">
    <a href="mailto:angel@example.com" class="contact-link flex items-center gap-3 bg-charm-surface border border-charm-border rounded px-5 py-3 text-charm-text">
      <span class="contact-icon text-charm-accent text-lg">✉</span>
      <span>angel@example.com</span>
    </a>

    <a href="https://github.com/whoAngeel" target="_blank" rel="noopener noreferrer" class="contact-link flex items-center gap-3 bg-charm-surface border border-charm-border rounded px-5 py-3 text-charm-text">
      <span class="contact-icon text-charm-accent text-lg">⌨</span>
      <span>github.com/whoAngeel</span>
    </a>

    <a href="https://linkedin.com/in/whoAngeel" target="_blank" rel="noopener noreferrer" class="contact-link flex items-center gap-3 bg-charm-surface border border-charm-border rounded px-5 py-3 text-charm-text">
      <span class="contact-icon text-charm-accent text-lg">🔗</span>
      <span>linkedin.com/in/whoAngeel</span>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    document.querySelectorAll(".contact-link").forEach((link) => {
      const icon = link.querySelector(".contact-icon");

      const iconBounce = icon
        ? gsap.to(icon, { x: 4, duration: 0.3, ease: "power2.out", paused: true })
        : null;

      link.addEventListener("mouseenter", () => {
        gsap.to(link, { borderColor: "var(--charm-accent)", duration: 0.25, ease: "power2.out" });
        gsap.to(link, { x: 3, duration: 0.25, ease: "power2.out" });
        iconBounce?.play();
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, { borderColor: "var(--charm-border)", x: 0, duration: 0.3, ease: "power2.out" });
        iconBounce?.reverse();
      });
    });
  }
</script>
