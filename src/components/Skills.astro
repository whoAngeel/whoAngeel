<section id="habilidades" class="max-w-2xl mx-auto w-full px-8 py-24">
  <h2 class="section-title text-4xl font-bold text-charm-text mb-12">Habilidades</h2>

  <div class="skills-group space-y-8">
    <div class="skill-cat">
      <h3 class="text-lg font-semibold text-charm-text mb-3">Backend</h3>
      <div class="flex flex-wrap gap-2">
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Python</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Go</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Node.js</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">FastAPI</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">PostgreSQL</span>
      </div>
    </div>

    <div class="skill-cat">
      <h3 class="text-lg font-semibold text-charm-text mb-3">Cloud & DevOps</h3>
      <div class="flex flex-wrap gap-2">
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">GCP</span>
