---
const categories = [
  {
    name: "Backend",
    items: ["Python", "Go", "Node.js", "NestJS", "FastAPI", "Express.js", "PostgreSQL", "MongoDB", "Redis"]
  },
  {
    name: "Cloud & DevOps",
    items: ["GCP", "GKE", "Cloud Functions", "PubSub", "Firestore", "Vertex AI", "Docker", "Kubernetes", "Cloud Run"]
  },
  {
    name: "Frontend",
    items: ["Astro", "React", "TypeScript", "Tailwind", "Flutter", "GSAP"]
  },
  {
    name: "AI & ML",
    items: ["LLM Multimodal", "YOLO", "n8n", "Qdrant", "LangChain"]
  },
  {
    name: "Herramientas",
    items: ["Git", "Linux", "Charm CLI", "Go TUI", "gcloud CLI"]
  }
];
---

<section id="habilidades" class="max-w-5xl mx-auto w-full px-8 py-24">
  <h2 class="section-title text-4xl font-bold text-charm-text mb-12">Habilidades</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      categories.map((cat, i) => (
        <div class="skill-cat" class:list={{ "md:col-span-2": i === categories.length - 1 }}>
          <h3 class="text-charm-accent font-mono text-sm font-semibold tracking-wide mb-4">
            <span class="text-charm-muted-soft">$ </span>{cat.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {cat.items.map((item) => (
              <span class="skill-tag bg-charm-surface border border-charm-border/60 px-3 py-1.5 text-sm text-charm-muted rounded hover:bg-charm-surface-strong hover:text-charm-text hover:border-charm-accent/40 hover:scale-105 transition-all duration-200 cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
