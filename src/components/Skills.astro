    <div class="skill-cat">
      <h3 class="text-lg font-semibold text-charm-text mb-3">Herramientas</h3>
      <div class="flex flex-wrap gap-2">
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Git</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Linux</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Charm CLI</span>
