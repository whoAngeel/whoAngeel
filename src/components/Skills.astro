        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Tailwind</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Flutter</span>
      </div>
    </div>

    <div class="skill-cat">
      <h3 class="text-lg font-semibold text-charm-text mb-3">AI & ML</h3>
      <div class="flex flex-wrap gap-2">
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">LLM Multimodal</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">YOLO</span>
