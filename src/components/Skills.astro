---
const categories = [
  {
    name: "Backend",
    items: ["Python", "Go", "Node.js", "NestJS", "FastAPI", "Express.js", "PostgreSQL", "MongoDB", "Redis"]
  },
  {
    name: "Cloud & DevOps",
    items: ["GCP", "GKE", "Cloud Functions", "PubSub", "Firestore", "Vertex AI", "Docker", "Kubernetes", "Cloud Run"]
  },
  {
    name: "Frontend",
    items: ["Astro", "React", "TypeScript", "Tailwind", "Flutter", "GSAP"]
  },
  {
    name: "AI & ML",
    items: ["LLM Multimodal", "YOLO", "n8n", "Qdrant", "LangChain"]
  },
  {
    name: "Herramientas",
    items: ["Git", "Linux", "Charm CLI", "Go TUI", "gcloud CLI"]
  }
];
---

<section id="habilidades" class="max-w-5xl mx-auto w-full px-8 py-24">
  <h2 class="section-title text-4xl font-bold text-charm-text mb-12">Habilidades</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      categories.map((cat, i) => (
        <div class:list={["skill-cat", { "md:col-span-2": i === categories.length - 1 }]}>
          <h3 class="flex items-center gap-2 text-charm-text font-semibold text-sm mb-4 tracking-wide">
            <span class="font-mono text-charm-accent font-normal tabular-nums">0{i + 1}</span>
            <span>{cat.name}</span>
            <span class="flex-1 h-px bg-charm-border/40"></span>
          </h3>
          <div class="flex flex-wrap gap-2">
            {cat.items.map((item) => (
              <span class="skill-tag bg-charm-surface border border-charm-border/50 px-3 py-1.5 text-sm text-charm-muted rounded hover:scale-105 hover:-translate-y-0.5 transition-[color,background,border-color] duration-200 cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style is:global>
  .skill-tag {
    will-change: transform, opacity;
  }
  .skill-tag:hover {
    background: rgba(124, 58, 237, 0.12);
    border-color: rgba(124, 58, 237, 0.5);
    color: var(--charm-accent-soft);
  }
  .skill-cat {
    will-change: transform, opacity;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    gsap.utils.toArray(".skill-cat").forEach((cat) => {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: cat,
          start: "top 85%",
          toggleActions: "play none none reverse"
        }
      });

      tl.from(cat, {
        y: 30,
        opacity: 0,
        duration: 0.5,
        ease: "power3.out"
      });

      tl.from(cat.querySelectorAll(".skill-tag"), {
        y: 12,
        opacity: 0,
        duration: 0.35,
        stagger: 0.06,
        ease: "power2.out"
      }, "-=0.2");
    });
  }
</script>
