        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Vertex AI</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Firestore</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Docker</span>
      </div>
    </div>

    <div class="skill-cat">
      <h3 class="text-lg font-semibold text-charm-text mb-3">Frontend</h3>
      <div class="flex flex-wrap gap-2">
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">Astro</span>
        <span class="skill-tag bg-charm-surface border border-charm-border px-3 py-1 text-sm text-charm-muted rounded">React</span>
