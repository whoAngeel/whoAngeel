---
---

<style is:global>
  .hero-name {
    font-family: "JetBrains Mono", "Onest", monospace;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .hero-glow {
    background: radial-gradient(
      circle at 50% 50%,
      rgba(124, 58, 237, 0.25) 0%,
      transparent 60%
    );
    mix-blend-mode: color-dodge;
  }
</style>

<section id="inicio" class="relative flex items-center justify-center min-h-screen px-8 overflow-hidden">
  <div class="hero-glow pointer-events-none absolute inset-0 z-0"></div>
  <div class="relative z-10 flex flex-row items-center justify-between w-full max-w-5xl gap-12">
    <div class="flex flex-col items-start text-left">
      <h1 class="hero-name text-5xl font-bold text-charm-text mb-3">
        Angel Jesus Zorrilla Cuevas
      </h1>

      <p class="hero-role text-charm-muted text-xl mb-8 font-medium">
        Ingeniero en Sistemas Computacionales
      </p>

      <p class="hero-desc text-charm-muted-soft max-w-prose text-balance leading-relaxed">
        Desarrollador backend y frontend.
        Apasionado por resolver problemas reales con tecnología bien hecha.
      </p>
    </div>
  </div>
</section>
