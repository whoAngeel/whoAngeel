---

<section id="proyectos" class="max-w-6xl mx-auto w-full px-8 py-24">
  <h2 class="section-title text-4xl font-bold text-charm-text mb-12">Proyectos</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      projects.map((p, i) => (
        <article
          class="project-card bg-charm-surface border border-charm-border border-t-2 border-t-charm-accent/10 rounded overflow-hidden group cursor-default"
          data-index={i}
        >
          <div class="project-img h-40 md:h-52 bg-charm-surface-strong border-b border-charm-border flex items-center justify-center text-charm-muted-soft text-xs select-none overflow-hidden relative">
            {p.images && p.images.length > 0 ? (
              <div class="relative w-full h-full" data-carousel={i}>
                {p.images.map((img, j) => (
                  <img
                    src={img}
                    alt={`${p.name} - ${j + 1}`}
                    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
                    class:list={j === 0 ? "opacity-100" : "opacity-0"}
                    data-img={j}
                  />
                ))}
                {p.images.length > 1 && (
                  <div class="carousel-nav absolute inset-0 z-10">
                    <div class="absolute inset-y-0 left-0 w-2/5 bg-gradient-to-r from-black/70 via-black/30 to-transparent flex items-center justify-start pl-2 cursor-pointer carousel-zone" data-nav="prev" role="button" tabindex="0" aria-label="Anterior">
                      <span class="carousel-arrow flex items-center justify-center w-8 h-8 rounded-full bg-black/60 text-charm-accent font-mono text-xl font-bold hover:bg-black/80 transition-colors">&lt;</span>
                    </div>
                    <div class="absolute inset-y-0 right-0 w-2/5 bg-gradient-to-l from-black/70 via-black/30 to-transparent flex items-center justify-end pr-2 cursor-pointer carousel-zone" data-nav="next" role="button" tabindex="0" aria-label="Siguiente">
                      <span class="carousel-arrow flex items-center justify-center w-8 h-8 rounded-full bg-black/60 text-charm-accent font-mono text-xl font-bold hover:bg-black/80 transition-colors">&gt;</span>
                    </div>
                  </div>
                )}
              </div>
            ) : (
              <span class="font-mono tracking-wide opacity-25 text-charm-muted-soft">[ {p.name.split(" ")[0].toLowerCase()} ]</span>
            )}
            {p.tags && p.tags.length > 0 && (
              <div class="tags-overlay absolute bottom-1.5 left-1.5 flex flex-wrap gap-1 z-10">
                {p.tags.map(tag => (
                  <span class="bg-charm-bg/85 backdrop-blur-sm text-charm-accent text-[10px] font-mono font-semibold px-1.5 py-0.5 rounded leading-none shadow-sm">{tag}</span>
                ))}
              </div>
            )}
          </div>

          <div class="px-5 py-4">
            <h3 class="text-xl md:text-2xl font-semibold text-charm-text">{p.name}</h3>

            <div class="flex flex-wrap gap-1.5 mt-2">
              {p.badges.map(badge => (
                <span class="project-badge bg-charm-surface-strong border border-charm-border/60 px-2 py-0.5 text-xs text-charm-muted rounded">{badge}</span>
              ))}
            </div>

            <div class="project-details overflow-hidden mt-0" style="max-height: 0; opacity: 0;">
              {p.winner && (
                <p class="text-charm-accent text-xs tracking-wide font-semibold mt-3 leading-relaxed">{p.winner}</p>
              )}
              <p class="text-sm md:text-base text-charm-muted mt-2 leading-relaxed">{p.detail}</p>
              {p.code && (
                <div class="flex gap-3 mt-3">
                  <a href={p.code} target="_blank" rel="noopener noreferrer" class="text-sm text-charm-accent hover:text-charm-accent-strong font-medium transition-colors">Codigo →</a>
                </div>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style is:global>
  .carousel-arrow {
    transition: opacity 0.2s, background 0.2s;
  }

  .carousel-zone {
    transition: opacity 0.2s;
  }

  .tags-overlay {
    transition: opacity 0.2s;
  }

  @media (hover: hover) {
    .carousel-arrow,
    .carousel-zone {
      opacity: 0;
    }
    .group:hover .carousel-arrow,
    .group:hover .carousel-zone {
      opacity: 1;
    }
    .group:hover .tags-overlay {
      opacity: 0;
    }
  }

  @media (hover: none) {
    .carousel-arrow,
    .carousel-zone {
      opacity: 1;
    }
    .tags-overlay {
      opacity: 1;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll(".project-card");
  const isTouch = window.matchMedia("(hover: none)").matches;
  const isReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  import gsap from "gsap";

  if (isTouch || isReduced) {
    cards.forEach((card) => {
      const details = card.querySelector(".project-details");
      if (details) {
        details.style.maxHeight = "none";
        details.style.opacity = "1";
        details.style.overflow = "visible";
      }
    });
  } else {
      cards.forEach((card) => {
        const details = card.querySelector(".project-details");
        const img = card.querySelector(".project-img");
        if (!details) return;

        const show = gsap.to(details, {
          maxHeight: 300,
          opacity: 1,
          duration: 0.4,
          ease: "power3.out",
          paused: true,
        });

        const lift = gsap.to(card, {
          y: -5,
          borderColor: "var(--charm-accent-soft)",
          duration: 0.35,
          ease: "power2.out",
          paused: true,
        });

        const imgReveal = img
          ? gsap.to(img, {
              filter: "brightness(1.1) contrast(1.05)",
              duration: 0.35,
              ease: "power2.out",
              paused: true,
            })
          : null;

        const topBorderTween = gsap.to(card, {
          borderTopColor: "var(--charm-accent)",
          duration: 0.35,
          ease: "power2.out",
          paused: true,
        });

        card.addEventListener("mouseenter", () => {
          show.play();
          lift.play();
          imgReveal?.play();
          topBorderTween.play();
        });

        card.addEventListener("mouseleave", () => {
          show.reverse();
          lift.reverse();
          imgReveal?.reverse();
          topBorderTween.reverse();
      });
    });
  }

  // Carousel — infinite loop cycling
  const idxMap = new Map();

  document.querySelectorAll("[data-carousel]").forEach((el) => {
    idxMap.set(el, 0);
  });

  document.querySelectorAll("[data-nav]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const container = btn.closest("[data-carousel]");
      const imgs = container.querySelectorAll("[data-img]");
      const total = imgs.length;
      if (total < 2) return;

      let curr = idxMap.get(container) || 0;
      const dir = btn.dataset.nav;
      const next = (((curr + (dir === "next" ? 1 : -1)) % total) + total) % total;

      imgs.forEach((img, j) => {
        img.classList.toggle("opacity-100", j === next);
        img.classList.toggle("opacity-0", j !== next);
      });

      idxMap.set(container, next);
    });
  });
</script>
