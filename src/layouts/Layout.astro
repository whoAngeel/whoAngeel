---
import BaseAstro from "../components/BaseAstro.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "whoAngeel", description = "Personal Portfolio de Angel Jesus Zorrilla Cuevas" } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <BaseAstro title={title} description={description}/>
    </head>
    <body>
        <div id="loader">
            <div id="loader-bar"></div>
        </div>
        <canvas id="grid-paint" aria-hidden="true"></canvas>
		<Header />
        <slot />
    </body>
    <script>
        (() => {
            const bar = document.getElementById("loader-bar");
            const wrap = document.getElementById("loader");
            if (!bar || !wrap) return;
            let w = 0;
            const step = () => {
                w += Math.random() * 8 + 2;
                if (w >= 100) { w = 100; bar.style.width = "100%"; }
                bar.style.width = w + "%";
                if (w < 100) requestAnimationFrame(step);
                else {
                    setTimeout(() => {
                        wrap.classList.add("loader-hidden");
                        setTimeout(() => wrap.remove(), 500);
                    }, 300);
                }
            };
            requestAnimationFrame(step);
        })();
    </script>
<style>
  body {
    cursor: none;
  }

  #grid-paint {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

    #loader {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 9999;
    background: transparent;
    transition: opacity 0.5s;
  }

  #loader-bar {
    height: 100%;
    width: 0%;
    background: var(--charm-accent);
    box-shadow:
      0 0 10px var(--charm-accent),
      0 0 20px var(--charm-accent);
    transition: width 0.1s linear;
  }

  #loader.loader-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #loader {
      display: none;
    }
  }

  @media (hover: none) {
    body {
      cursor: auto;
    }
    #grid-paint {
      display: none;
    }
  }
</style>

<script>
  (() => {
    if (window.matchMedia("(hover: none)").matches) return;

    const canvas = document.getElementById("grid-paint");
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    const PX = 16;
    const FADE = 800;

    let w, h;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    const cells = new Map();
    let lastX, lastY;

    function paintAt(mx, my) {
      const c = Math.floor(mx / PX);
      const r = Math.floor(my / PX);
      if (c < 0 || r < 0 || c * PX > w || r * PX > h) return;
      const key = c + ":" + r;
      cells.set(key, performance.now());
      lastCellKey = key;
    }

    function onMove(e) {
      const mx = e.clientX;
      const my = e.clientY;
      if (lastX !== undefined) {
        const dx = mx - lastX;
        const dy = my - lastY;
        const n = Math.max(Math.abs(dx), Math.abs(dy));
        for (let t = 0; t <= n; t++) {
          paintAt(lastX + (dx * t) / n, lastY + (dy * t) / n);
        }
      } else {
        paintAt(mx, my);
      }
      lastX = mx;
      lastY = my;
    }

    let raf;
    let idleTimer;
    let isIdle = false;
    let blinkOn = true;
    let blinkRaf;
    let lastCellKey;
    let overInteractive = false;
    const IDLE_MS = 1500;

    function isInteractive(el) {
      if (!el) return false;
      const tag = el.tagName.toLowerCase();
      if (["button", "a", "input", "textarea", "select"].includes(tag)) return true;
      if (el.closest("[role=button], .contact-link, .carousel-zone, .cta-btn, .nav-link, .project-card, .skill-tag, .project-badge, .tags-overlay, button")) return true;
      return false;
    }

    function tick() {
      if (overInteractive) { raf = null; return; }
      const now = performance.now();
      ctx.clearRect(0, 0, w, h);

      for (const [key, t0] of cells) {
        const age = now - t0;
        if (age > FADE) {
          if (isIdle && key === lastCellKey) { cells.set(key, now); continue; }
          cells.delete(key); continue;
        }
        let a;
        if (isIdle && key === lastCellKey) {
          a = blinkOn ? "1" : "0";
        } else {
          a = (1 - age / FADE).toFixed(3);
        }
        ctx.fillStyle = "rgba(157,121,243," + a + ")";
        const [c, r] = key.split(":").map(Number);
        ctx.fillRect(c * PX, r * PX, PX, PX);
      }

      if (cells.size > 0) raf = requestAnimationFrame(tick);
      else raf = null;
    }

    function start() { if (!raf && !overInteractive) raf = requestAnimationFrame(tick); }

    function resetIdle() {
      clearTimeout(idleTimer);
      clearInterval(blinkRaf);
      isIdle = false;
      blinkOn = true;
      idleTimer = setTimeout(() => {
        if (overInteractive) return;
        if (cells.size === 0 && lastCellKey) cells.set(lastCellKey, performance.now());
        isIdle = true;
        if (!raf) raf = requestAnimationFrame(tick);
        blinkRaf = setInterval(() => { blinkOn = !blinkOn; }, 530);
      }, IDLE_MS);
    }

    function onDocMove(e) {
      const target = e.target;
      overInteractive = isInteractive(target);
      if (overInteractive) {
        document.body.style.cursor = "auto";
        ctx.clearRect(0, 0, w, h);
        if (raf) { cancelAnimationFrame(raf); raf = null; }
        clearTimeout(idleTimer);
        clearInterval(blinkRaf);
        isIdle = false;
        return;
      }
      document.body.style.cursor = "none";
      onMove(e);
      start();
      resetIdle();
    }

    document.addEventListener("mousemove", onDocMove);
    document.addEventListener("mouseleave", () => { lastX = lastY = undefined; clearTimeout(idleTimer); clearInterval(blinkRaf); isIdle = false; });
    window.addEventListener("resize", resize);
    resize();
  })();
</script>
</html>
